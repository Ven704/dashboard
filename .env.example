# Supabase project URL (safe to expose to the browser if you use anon later)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Server-only: create in Supabase Dashboard → Settings → API → service_role
# Never commit real keys. On Vercel: add as encrypted env var (not NEXT_PUBLIC_*).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: public anon key if you switch to client-side + RLS later
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Table that stores bot trades (default: trades)
# SUPABASE_TRADES_TABLE=trades

# Column used for descending sort (default: created_at)
# SUPABASE_TRADES_ORDER_COLUMN=created_at

# Max rows to load per request (default 500, max 5000)
# TRADES_FETCH_LIMIT=500

# Max rows for reviews, patterns, signals, strategy, wallets (default 200, max 1000)
# SUPABASE_LIST_LIMIT=200
